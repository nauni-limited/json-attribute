{
  "name": "nauni-limited/json-attribute",
  "description": "Map JSON into typed PHP objects using attributes (PHP 8.0+)",
  "license": "MIT",
  "authors": [
    {
      "name": "Tamas Dobo",
      "email": "tamas@nauni.co.uk"
    }
  ],
  "require": {
    "php": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "phpstan/phpstan": "^1.10",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan-phpunit": "^1.3",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "Nauni\\JSON\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nauni\\JSON\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
